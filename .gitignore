# AWEOMA .gitignore
# Sensible Dateien niemals einchecken!

# ============================================================
# WireGuard – echte Keys und Configs
# ============================================================
config/wireguard/wg0.conf
config/wireguard/wg1-protonvpn.conf
config/wireguard/*.conf
!config/wireguard/*.conf.example

# ============================================================
# Umgebungsvariablen (.env Dateien)
# ============================================================
.env
config/**/.env
!config/**/.env.example

# ============================================================
# Traefik – ACME/TLS Zertifikate (enthalten private Schluessel!)
# ============================================================
config/traefik/acme/
*.json
!package.json
!package-lock.json

# ============================================================
# Backups
# ============================================================
*.tar.gz
*.tar.bz2
*.zip
backups/

# ============================================================
# Logs
# ============================================================
*.log
logs/

# ============================================================
# Betriebssystem-spezifisch
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ============================================================
# Editor / IDE
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ============================================================
# Python (fuer eventuelle Skripte)
# ============================================================
__pycache__/
*.py[cod]
venv/
.venv/

# ============================================================
# Temporaere Dateien
# ============================================================
tmp/
temp/
*.tmp
