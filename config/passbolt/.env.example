# Passbolt Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.
# ACHTUNG: .env NIEMALS in Git einchecken!

# ============================================================
# Domain
# ============================================================
# Subdomain unter der Passbolt erreichbar ist
PASSBOLT_DOMAIN=pass.deine-domain.de

# ============================================================
# Datenbank (MariaDB)
# ============================================================
PASSBOLT_DB_NAME=passbolt
PASSBOLT_DB_USER=passbolt
# Starkes Passwort generieren: openssl rand -base64 32
PASSBOLT_DB_PASSWORD=SICHERES_DB_PASSWORT_HIER

# ============================================================
# E-Mail (SMTP fuer Benachrichtigungen und Einladungen)
# ============================================================
# Absender-Adresse
PASSBOLT_EMAIL_FROM=passbolt@deine-domain.de

# SMTP-Server Einstellungen (z.B. Gmail, Mailgun, eigener Server)
PASSBOLT_SMTP_HOST=smtp.deine-domain.de
PASSBOLT_SMTP_PORT=587
PASSBOLT_SMTP_USER=SMTP_BENUTZERNAME
PASSBOLT_SMTP_PASSWORD=SMTP_PASSWORT

# ============================================================
# Zeitzone
# ============================================================
TZ=Europe/Berlin

# ============================================================
# Erster Admin-User
# Nach dem Start erstellen mit:
# docker exec passbolt su -m -c "/usr/share/php/passbolt/bin/cake \
#   passbolt register_user -u DEINE_EMAIL -f Vorname -l Nachname -r admin" -s /bin/sh www-data
# ============================================================
