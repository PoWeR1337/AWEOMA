# Opencloud Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.
# ACHTUNG: .env NIEMALS in Git einchecken!

# Domain unter der Opencloud erreichbar ist
OPENCLOUD_DOMAIN=cloud.deine-domain.de

# Admin-Passwort fuer den ersten Login (danach aendern!)
OPENCLOUD_ADMIN_PASSWORD=SICHERES_PASSWORT_HIER

# Zeitzone
TZ=Europe/Berlin
